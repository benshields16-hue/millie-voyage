# Copy to .env and set long random values. NEVER commit .env (it holds the secrets).
# Generate tokens e.g.:  node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"

# WRITE credential — the boat's phone uses this to POST its position.
# Entered once into the PWA's "Share live position" card; never baked into the app.
INGEST_TOKEN=change-me-to-a-long-random-ingest-secret

# READ credential — embedded in the family link:  https://<host>/t/<VIEW_TOKEN>
# Read-only; cannot post or reveal the ingest token.
VIEW_TOKEN=change-me-to-a-long-random-view-token

# Local port the Cloudflare Tunnel points at.
PORT=8787

# How much recent track to keep/serve (rolling window).
RETENTION_HOURS=36

# The PWA origin allowed to POST (CORS). Your GitHub Pages site.
ALLOW_ORIGIN=https://benshields16-hue.github.io
